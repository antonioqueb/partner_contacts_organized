<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_contacts_organized" model="ir.ui.view">
        <field name="name">res.partner.form.contacts.organized</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">

            <!-- Reemplazar la pestaña completa de contactos -->
            <xpath expr="//page[@name='contact_addresses']" position="replace">
                <page string="Contactos y Direcciones" name="contact_addresses" autofocus="autofocus">

                    <!-- ========== BOTONES DE CREACIÓN ========== -->
                    <div class="o_partner_contacts_actions d-flex gap-2 mb-4 flex-wrap">
                        <field name="child_ids" invisible="1"/>
                        <button
                            name="action_create_contact"
                            string="➕ Crear Contacto"
                            type="object"
                            class="btn btn-primary"
                            icon="fa-user-plus"
                            context="{'default_parent_id': id, 'default_type': 'contact', 'default_street': street, 'default_street2': street2, 'default_city': city, 'default_state_id': state_id, 'default_zip': zip, 'default_country_id': country_id, 'default_lang': lang, 'default_user_id': user_id}"
                        />
                        <button
                            name="action_create_delivery_address"
                            string="📦 Crear Dirección de Entrega"
                            type="object"
                            class="btn btn-success"
                            icon="fa-truck"
                            context="{'default_parent_id': id, 'default_type': 'delivery', 'default_lang': lang, 'default_user_id': user_id}"
                        />
                        <button
                            name="action_create_invoice_address"
                            string="📄 Crear Dirección de Factura"
                            type="object"
                            class="btn btn-warning"
                            icon="fa-file-text-o"
                            context="{'default_parent_id': id, 'default_type': 'invoice', 'default_lang': lang, 'default_user_id': user_id}"
                        />
                    </div>

                    <!-- ========== SECCIÓN: CONTACTOS ========== -->
                    <div class="o_partner_section mb-4">
                        <div class="o_partner_section_header d-flex align-items-center gap-2 mb-2 pb-2 border-bottom">
                            <i class="fa fa-users fa-lg text-primary"/>
                            <h3 class="mb-0 text-primary">Contactos</h3>
                        </div>
                        <field name="child_ids"
                               mode="kanban"
                               nolabel="1"
                               domain="[('type', '=', 'contact')]"
                               context="{'default_parent_id': id, 'default_type': 'contact', 'default_street': street, 'default_street2': street2, 'default_city': city, 'default_state_id': state_id, 'default_zip': zip, 'default_country_id': country_id, 'default_lang': lang, 'default_user_id': user_id}">
                            <kanban>
                                <field name="color"/>
                                <field name="type"/>
                                <field name="is_company"/>
                                <templates>
                                    <t t-name="card" class="flex-row">
                                        <aside class="o_kanban_aside_full">
                                            <field name="avatar_128" class="o_kanban_image_fill w-100" widget="image" options="{'img_class': 'object-fit-cover'}" alt="Contact image"/>
                                        </aside>
                                        <main class="ps-2 ps-md-0">
                                            <field name="name" invisible="not name" class="fw-bold"/>
                                            <div t-if="record.function.raw_value" class="text-muted small">
                                                <i class="fa fa-fw me-1 fa-suitcase" title="Puesto"/>
                                                <field name="function"/>
                                            </div>
                                            <div t-if="record.email.raw_value" class="text-truncate">
                                                <i class="fa fa-fw me-1 fa-envelope text-primary" title="Email"/>
                                                <field name="email"/>
                                            </div>
                                            <div t-if="record.phone.raw_value">
                                                <i class="fa fa-fw me-1 fa-phone text-primary" title="Teléfono"/>
                                                <field name="phone"/>
                                            </div>
                                        </main>
                                    </t>
                                </templates>
                            </kanban>
                            <form string="Contacto">
                                <sheet>
                                    <field name="type" invisible="1"/>
                                    <div class="d-flex align-items-center gap-3">
                                        <field name="image_1920" widget="contact_image" nolabel="1" options="{'preview_image': 'avatar_128', 'size': [100,100], 'img_class': 'rounded border'}"/>
                                        <div class="flex-grow-1">
                                            <h3>
                                                <field name="name" class="d-block" string="Nombre" default_focus="1" required="1" placeholder="Nombre del contacto"/>
                                            </h3>
                                            <div class="row flex-row">
                                                <div class="d-flex align-items-baseline">
                                                    <i class="fa fa-fw me-1 fa-envelope text-primary" title="Email"/>
                                                    <field name="email" widget="email" class="w-100" placeholder="Email"/>
                                                </div>
                                                <div class="d-flex align-items-baseline">
                                                    <i class="fa fa-fw me-1 fa-phone text-primary" title="Teléfono"/>
                                                    <field name="phone" widget="phone" class="w-100" placeholder="Teléfono"/>
                                                </div>
                                                <div class="d-flex align-items-baseline">
                                                    <i class="fa fa-fw me-1 fa-suitcase text-primary" title="Puesto"/>
                                                    <field name="function" placeholder="Puesto / Cargo"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <group>
                                        <field name="company_id" invisible="1"/>
                                        <label for="comment"/>
                                        <field name="comment" options="{'height': 100}" placeholder="Notas internas..." nolabel="1"/>
                                    </group>
                                    <field name="lang" invisible="True"/>
                                </sheet>
                            </form>
                        </field>
                    </div>

                    <!-- ========== SECCIÓN: DIRECCIONES DE ENTREGA ========== -->
                    <div class="o_partner_section mb-4">
                        <div class="o_partner_section_header d-flex align-items-center gap-2 mb-2 pb-2 border-bottom">
                            <i class="fa fa-truck fa-lg text-success"/>
                            <h3 class="mb-0 text-success">Direcciones de Entrega</h3>
                        </div>
                        <field name="child_ids"
                               mode="kanban"
                               nolabel="1"
                               domain="[('type', '=', 'delivery')]"
                               context="{'default_parent_id': id, 'default_type': 'delivery', 'default_lang': lang, 'default_user_id': user_id}">
                            <kanban>
                                <field name="color"/>
                                <field name="type"/>
                                <templates>
                                    <t t-name="card" class="flex-row">
                                        <aside class="o_kanban_aside_full">
                                            <div class="d-flex align-items-center justify-content-center h-100 bg-success-subtle" style="min-width:60px;">
                                                <i class="fa fa-truck fa-2x text-success"/>
                                            </div>
                                        </aside>
                                        <main class="ps-2 ps-md-0">
                                            <field name="name" invisible="not name" class="fw-bold"/>
                                            <field name="type" invisible="name" class="fw-bold"/>
                                            <div t-if="record.street.raw_value" class="text-truncate">
                                                <i class="fa fa-fw me-1 fa-map-marker text-success" title="Dirección"/>
                                                <field name="street"/>
                                            </div>
                                            <div t-if="record.city.raw_value || record.state_id.raw_value">
                                                <span class="ms-3">
                                                    <field name="city"/>
                                                    <span t-if="record.city.raw_value and record.state_id.raw_value">, </span>
                                                    <field name="state_id"/>
                                                </span>
                                            </div>
                                            <div t-if="record.zip.raw_value || record.country_id.raw_value">
                                                <span class="ms-3">
                                                    <field name="zip"/>
                                                    <span t-if="record.zip.raw_value and record.country_id.raw_value"> - </span>
                                                    <field name="country_id"/>
                                                </span>
                                            </div>
                                            <div t-if="record.phone.raw_value">
                                                <i class="fa fa-fw me-1 fa-phone text-success" title="Teléfono"/>
                                                <field name="phone"/>
                                            </div>
                                        </main>
                                    </t>
                                </templates>
                            </kanban>
                            <form string="Dirección de Entrega">
                                <sheet>
                                    <field name="type" invisible="1"/>
                                    <group>
                                        <group>
                                            <field name="name" string="Referencia / Nombre" placeholder="Ej: Bodega Norte, Sucursal Centro..."/>
                                            <span class="o_form_label o_td_label">
                                                <b>Dirección de Entrega</b>
                                            </span>
                                            <div class="o_address_format" name="div_address">
                                                <field name="street" placeholder="Calle..." class="o_address_street"/>
                                                <field name="street2" placeholder="Calle 2..." class="o_address_street"/>
                                                <field name="city" placeholder="Ciudad" class="o_address_city"/>
                                                <field name="state_id" class="o_address_state" placeholder="Estado" options="{'no_open': True, 'no_quick_create': True}" context="{'country_id': country_id, 'default_country_id': country_id, 'zip': zip}"/>
                                                <field name="zip" placeholder="C.P." class="o_address_zip"/>
                                                <field name="country_id" placeholder="País" class="o_address_country" options="{&quot;no_open&quot;: True, &quot;no_create&quot;: True}"/>
                                            </div>
                                        </group>
                                        <group>
                                            <field name="phone" widget="phone" placeholder="Teléfono de contacto"/>
                                            <field name="email" widget="email" placeholder="Email (opcional)"/>
                                        </group>
                                    </group>
                                    <group>
                                        <field name="company_id" invisible="1"/>
                                        <label for="comment"/>
                                        <field name="comment" options="{'height': 100}" placeholder="Notas de entrega (horarios, indicaciones especiales)..." nolabel="1"/>
                                    </group>
                                    <field name="lang" invisible="True"/>
                                </sheet>
                            </form>
                        </field>
                    </div>

                    <!-- ========== SECCIÓN: DIRECCIONES DE FACTURA ========== -->
                    <div class="o_partner_section mb-4">
                        <div class="o_partner_section_header d-flex align-items-center gap-2 mb-2 pb-2 border-bottom">
                            <i class="fa fa-file-text-o fa-lg text-warning"/>
                            <h3 class="mb-0 text-warning">Direcciones de Factura</h3>
                        </div>
                        <field name="child_ids"
                               mode="kanban"
                               nolabel="1"
                               domain="[('type', '=', 'invoice')]"
                               context="{'default_parent_id': id, 'default_type': 'invoice', 'default_lang': lang, 'default_user_id': user_id}">
                            <kanban>
                                <field name="color"/>
                                <field name="type"/>
                                <templates>
                                    <t t-name="card" class="flex-row">
                                        <aside class="o_kanban_aside_full">
                                            <div class="d-flex align-items-center justify-content-center h-100 bg-warning-subtle" style="min-width:60px;">
                                                <i class="fa fa-file-text-o fa-2x text-warning"/>
                                            </div>
                                        </aside>
                                        <main class="ps-2 ps-md-0">
                                            <field name="name" invisible="not name" class="fw-bold"/>
                                            <field name="type" invisible="name" class="fw-bold"/>
                                            <div t-if="record.street.raw_value" class="text-truncate">
                                                <i class="fa fa-fw me-1 fa-map-marker text-warning" title="Dirección"/>
                                                <field name="street"/>
                                            </div>
                                            <div t-if="record.city.raw_value || record.state_id.raw_value">
                                                <span class="ms-3">
                                                    <field name="city"/>
                                                    <span t-if="record.city.raw_value and record.state_id.raw_value">, </span>
                                                    <field name="state_id"/>
                                                </span>
                                            </div>
                                            <div t-if="record.zip.raw_value || record.country_id.raw_value">
                                                <span class="ms-3">
                                                    <field name="zip"/>
                                                    <span t-if="record.zip.raw_value and record.country_id.raw_value"> - </span>
                                                    <field name="country_id"/>
                                                </span>
                                            </div>
                                            <div t-if="record.vat.raw_value">
                                                <i class="fa fa-fw me-1 fa-building text-warning" title="RFC"/>
                                                <field name="vat"/>
                                            </div>
                                        </main>
                                    </t>
                                </templates>
                            </kanban>
                            <form string="Dirección de Factura">
                                <sheet>
                                    <field name="type" invisible="1"/>
                                    <group>
                                        <group>
                                            <field name="name" string="Razón Social / Nombre" placeholder="Ej: Empresa S.A. de C.V."/>
                                            <span class="o_form_label o_td_label">
                                                <b>Dirección Fiscal</b>
                                            </span>
                                            <div class="o_address_format" name="div_address">
                                                <field name="street" placeholder="Calle..." class="o_address_street"/>
                                                <field name="street2" placeholder="Calle 2..." class="o_address_street"/>
                                                <field name="city" placeholder="Ciudad" class="o_address_city"/>
                                                <field name="state_id" class="o_address_state" placeholder="Estado" options="{'no_open': True, 'no_quick_create': True}" context="{'country_id': country_id, 'default_country_id': country_id, 'zip': zip}"/>
                                                <field name="zip" placeholder="C.P." class="o_address_zip"/>
                                                <field name="country_id" placeholder="País" class="o_address_country" options="{&quot;no_open&quot;: True, &quot;no_create&quot;: True}"/>
                                            </div>
                                        </group>
                                        <group>
                                            <field name="vat" string="RFC" placeholder="RFC"/>
                                            <field name="phone" widget="phone" placeholder="Teléfono"/>
                                            <field name="email" widget="email" placeholder="Email para facturación"/>
                                        </group>
                                    </group>
                                    <group>
                                        <field name="company_id" invisible="1"/>
                                        <label for="comment"/>
                                        <field name="comment" options="{'height': 100}" placeholder="Notas de facturación..." nolabel="1"/>
                                    </group>
                                    <field name="lang" invisible="True"/>
                                </sheet>
                            </form>
                        </field>
                    </div>

                </page>
            </xpath>

        </field>
    </record>

</odoo>
